# =========================================================================
# CloudNest — Environment Variables
# =========================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# =========================================================================

# PostgreSQL database password
DB_PASSWORD=your_database_password_here

# Hibernate DDL mode (use 'update' for dev, 'validate' for production)
DDL_AUTO=update

# Show SQL queries in console (true for dev, false for production)
SHOW_SQL=false

# Base path for file storage (absolute path recommended for production)
# STORAGE_BASE_PATH=/var/cloudnest/storage
