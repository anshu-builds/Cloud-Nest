# =========================================================================
# CloudNest — Git Ignore Rules
# =========================================================================

# Environment secrets — NEVER commit
.env

# Documentation (local only)
Doc/

# Maven build output
target/

# Runtime file storage (generated at startup)
storage/

# IDE files
.idea/
*.iml
.vscode/
*.swp
*.swo
*~

# OS artifacts
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Compiled class files
*.class

# Package files
*.jar
*.war
*.ear
